# ── Database ──────────────────────────────────────────────────
# Neon (recommended for hosted): https://neon.tech
# DATABASE_URL=postgresql://aiui:xxx@ep-cool-name-123.us-east-2.aws.neon.tech/aiui?sslmode=require
#
# Local PostgreSQL:
DATABASE_URL=postgresql://aiui:aiui@127.0.0.1:5432/aiui

# ── Auth (required in production) ────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters

# ── MCP Server ───────────────────────────────────────────────
# Set to enable HTTP mode (omit for stdio mode)
# MCP_SERVER_PORT=8080

# Allowed CORS origins (comma-separated, default: *)
# MCP_CORS_ORIGINS=https://app.aiui.dev,https://claude.ai

# Rate limit: requests per minute per API key (default: 60)
# MCP_RATE_LIMIT=60

# ── Database Pool ────────────────────────────────────────────
# Max concurrent connections (default: 20, Neon free tier limit: 20)
# DB_POOL_MAX=20

# ── Docker Compose (production overrides) ────────────────────
# POSTGRES_PASSWORD=change-me-in-production
