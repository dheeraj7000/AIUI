{
  "mcpServers": {
    "aiui": {
      "command": "node",
      "args": ["/home/AIUI/apps/mcp-server/dist/index.js", "--local"],
      "env": {
        "DATABASE_URL": "postgresql://aiui:aiui@127.0.0.1:5432/aiui"
      }
    },
    "spoq": {
      "command": "spoq",
      "args": ["mcp"]
    }
  }
}
