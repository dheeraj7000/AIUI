# ── Required ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://aiui:aiui@127.0.0.1:5432/aiui

# ── HTTP Mode (set to enable remote MCP access) ──────────────
# Omit to run in stdio mode (local Claude Code usage via .mcp.json)
# MCP_SERVER_PORT=8080

# URL of the AIUI web console (required in HTTP mode)
# AIUI_WEB_URL=https://app.aiui.dev

# ── Optional ─────────────────────────────────────────────────
# Comma-separated allowed CORS origins (default: *)
# MCP_CORS_ORIGINS=https://app.aiui.dev,https://claude.ai

# Max concurrent MCP sessions (default: 1000)
# MCP_MAX_SESSIONS=1000

# Rate limit: requests per minute per API key (default: 60)
# MCP_RATE_LIMIT=60
