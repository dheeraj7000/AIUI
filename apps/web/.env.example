# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://aiui:aiui@127.0.0.1:5432/aiui

# ── Auth ──────────────────────────────────────────────────────
# Required in production. Omit for local dev (uses built-in default).
# JWT_SECRET=your-secret-here-min-32-chars

# Cognito (production only — local auth works without these)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxx
NEXT_PUBLIC_COGNITO_REGION=us-east-1

# ── MCP ───────────────────────────────────────────────────────
# Public URL of the remote MCP server (shown in API key setup snippets)
# NEXT_PUBLIC_MCP_URL=https://mcp.aiui.dev/mcp

# ── AWS (production only) ─────────────────────────────────────
# S3_ASSETS_BUCKET=aiui-assets-prod
# S3_BUNDLES_BUCKET=aiui-bundles-prod
# S3_PREVIEWS_BUCKET=aiui-previews-prod
