# ── Database ──────────────────────────────────────────────────
# Neon (recommended): get a free connection string at https://neon.tech
# DATABASE_URL=postgresql://aiui:xxx@ep-cool-name-123.us-east-2.aws.neon.tech/aiui?sslmode=require
#
# Local PostgreSQL:
DATABASE_URL=postgresql://aiui:aiui@127.0.0.1:5432/aiui

# ── Auth ──────────────────────────────────────────────────────
# Required in production. Omit for local dev (uses built-in default).
# JWT_SECRET=your-secret-here-min-32-chars

# ── MCP ───────────────────────────────────────────────────────
# Public URL of the remote MCP server (shown in API key setup snippets)
# NEXT_PUBLIC_MCP_URL=https://aiui.store/mcp
