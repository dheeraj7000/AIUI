# ── Database ──────────────────────────────────────────────────
# Neon (recommended): get a free connection string at https://neon.tech
# DATABASE_URL=postgresql://aiui:xxx@ep-cool-name-123.us-east-2.aws.neon.tech/aiui?sslmode=require
#
# Local PostgreSQL:
DATABASE_URL=postgresql://aiui:aiui@127.0.0.1:5432/aiui

# ── Auth ──────────────────────────────────────────────────────
# REQUIRED — app will not start without this. Generate with:
#   openssl rand -base64 32
JWT_SECRET=

# ── MCP ───────────────────────────────────────────────────────
# Public URL of the remote MCP server (shown in API key setup snippets)
# NEXT_PUBLIC_MCP_URL=https://aiui.store/mcp

# ── Google OAuth (optional) ───────────────────────────────────
# Leave blank to disable "Continue with Google". When unset, the sign-in
# button gracefully redirects back with a "not configured" message instead
# of returning 500.
#
# 1. Create credentials at https://console.cloud.google.com/apis/credentials
#    (OAuth client ID, application type "Web application")
# 2. Add http://localhost:3000/api/auth/google/callback as an authorized
#    redirect URI for local dev (and your prod URL for production)
# 3. Paste the values below
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── App URL (optional) ────────────────────────────────────────
# Used by the /status page to call /api/health server-side. Defaults to
# http://localhost:3000 when unset.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
